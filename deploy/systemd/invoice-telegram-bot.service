[Unit]
Description=Invoice Telegram Bot
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/invoice/backend
EnvironmentFile=/opt/invoice/backend/.env
ExecStart=/opt/invoice/backend/.venv/bin/python -m app.bot.telegram_bot
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
